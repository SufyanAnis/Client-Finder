# Set ONE of these. The server auto-detects which provider to use.

# Free — get a key at https://aistudio.google.com (no credit card for the free tier):
GEMINI_API_KEY=

# Paid — get a key at https://console.anthropic.com (Settings -> API Keys):
# ANTHROPIC_API_KEY=sk-ant-your-real-key

# Optional model overrides:
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_MODEL=claude-sonnet-4-6
