# The server auto-detects the provider from whichever key is set.

# --- Free path (recommended): Groq LLM + Tavily web search ---
# Groq (free): https://console.groq.com  -> API Keys
GROQ_API_KEY=
# Tavily (free web search, needed so Groq finds REAL companies): https://tavily.com
TAVILY_API_KEY=

# --- Paid alternative: Anthropic (native web search, no Tavily needed) ---
# ANTHROPIC_API_KEY=sk-ant-your-real-key

# --- Gemini (free tier only in some regions; not Pakistan) ---
# GEMINI_API_KEY=

# Optional model overrides:
# GROQ_MODEL=llama-3.3-70b-versatile
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GEMINI_MODEL=gemini-2.0-flash

# --- Inbound "Request services" form (/request) ---
# Email each submission to you (free): create a key at https://web3forms.com with
# the inbox email you want leads sent to.
WEB3FORMS_ACCESS_KEY=
# Save submissions to the in-app inbox (/inbox) — free Postgres at https://supabase.com
# (Project Settings -> API). Use the SERVICE ROLE key (server-only, never shipped to the browser).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Passphrase that unlocks /inbox (pick anything long).
ADMIN_TOKEN=
